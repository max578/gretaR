linters: linters_with_defaults(
    line_length_linter(100L),
    object_name_linter(styles = c("snake_case", "symbols")),
    commented_code_linter = NULL,
    object_usage_linter = NULL,
    cyclocomp_linter = NULL
  )
exclusions: list(
    "tests/testthat.R",
    "inst",
    "vignettes"
  )
encoding: "UTF-8"
